# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies - DON'T COMMIT (too large, use npm install)
node_modules/

# Expo - DON'T COMMIT (generated/cache files)
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files - DON'T COMMIT (contains personal API URLs/secrets)
.env
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders - DON'T COMMIT (generated by expo prebuild)
/ios
/android
