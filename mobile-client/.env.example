# API CONFIGURATION (MOBILE CLIENT)
# This file defines the backend API URL used by the mobile app.


# INSTRUCTIONS:
# 1. Copy this file and rename it to `.env`
# 2. Update the API URL according to your environment
# 3. Do NOT commit the `.env` file to Git


# The app will automatically read this value using:
# process.env.EXPO_PUBLIC_API_URL

# Choose ONE of the following options:
# --------------------------------------------

# Android Emulator (recommended for emulator)
# Uses a special IP that maps to the host machine
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000/api

# iOS Simulator
# EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Physical Mobile Device (Expo Go on phone)
# Replace <YOUR_LOCAL_IP> with your computer's local IP address
# Example: http://195.158.1.33:3000/api
# EXPO_PUBLIC_API_URL=http://<YOUR_LOCAL_IP>:3000/api
